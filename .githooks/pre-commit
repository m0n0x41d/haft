#!/bin/bash
set -e

# Mirror of CI pipeline (.github/workflows/ci.yml)
# Runs the same checks locally before commit.

STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
STAGED_MCP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^src/mcp/' || true)

if [ -z "$STAGED_MCP_FILES" ]; then
    exit 0
fi

echo "Pre-commit: running CI checks..."
cd src/mcp

# 1. go mod tidy (mirrors CI "Check go mod tidy" step)
echo "  → go mod tidy"
go mod tidy
if ! git diff --exit-code go.mod go.sum > /dev/null 2>&1; then
    echo "ERROR: go.mod/go.sum not tidy. Changes auto-applied — stage them and retry."
    exit 1
fi

# 2. golangci-lint (mirrors CI "Lint" job — v2.1.6)
if command -v golangci-lint &> /dev/null; then
    echo "  → golangci-lint"
    golangci-lint run --timeout=5m ./... || {
        echo "ERROR: Lint failed. Fix issues above."
        exit 1
    }
else
    # Fallback: at least check formatting
    echo "  → gofmt (golangci-lint not installed — install for full lint)"
    UNFORMATTED=$(gofmt -l . 2>/dev/null | head -10 || true)
    if [ -n "$UNFORMATTED" ]; then
        echo "ERROR: Files need formatting:"
        echo "$UNFORMATTED"
        echo "Run: gofmt -w ."
        exit 1
    fi
fi

# 3. go test -race (mirrors CI "Run tests" step)
echo "  → go test -race"
go test -race -short ./... || {
    echo "ERROR: Tests failed."
    exit 1
}

# 4. go build (mirrors CI "Build binary" step)
echo "  → go build"
go build -o /dev/null -trimpath . || {
    echo "ERROR: Build failed."
    exit 1
}

echo "Pre-commit: all checks passed."
