{
  "$schema": "https://raw.githubusercontent.com/nicerschaee/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "Haft",
  "version": "0.1.0",
  "identifier": "com.haft.desktop",
  "build": {
    "frontendDist": "../desktop/frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Haft",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0f0f0f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Engineering governance desktop",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
