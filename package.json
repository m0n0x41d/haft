{
  "name": "quint-code",
  "displayName": "Quint Code - FPF Engineering Assistant",
  "description": "First Principles Framework (FPF) for structured AI-assisted software engineering via GitHub Copilot Chat.",
  "version": "0.1.0",
  "publisher": "quint-code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/m0n0x41d/quint-code"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "llm",
    "fpf",
    "engineering",
    "decision-framework",
    "mcp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "quint-code.chat",
        "fullName": "Quint Code",
        "name": "quint",
        "description": "FPF engineering assistant for structured, evidence-based decisions",
        "isSticky": true,
        "commands": [
          {
            "name": "init",
            "description": "Initialize FPF project structure"
          },
          {
            "name": "status",
            "description": "Show current FPF phase and context"
          },
          {
            "name": "hypothesize",
            "description": "Propose a new hypothesis (L0)"
          },
          {
            "name": "verify",
            "description": "Verify a hypothesis (L0 -> L1)"
          },
          {
            "name": "validate",
            "description": "Validate with tests (L1 -> L2)"
          },
          {
            "name": "audit",
            "description": "Audit risks for a hypothesis"
          },
          {
            "name": "decide",
            "description": "Finalize a decision (DRR)"
          },
          {
            "name": "tree",
            "description": "Visualize assurance tree for a holon"
          },
          {
            "name": "reff",
            "description": "Calculate effective reliability (R_eff)"
          },
          {
            "name": "decay",
            "description": "Check evidence freshness"
          },
          {
            "name": "context",
            "description": "Record bounded context (vocabulary + invariants)"
          },
          {
            "name": "help",
            "description": "Show available commands"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "quint-code.init",
        "title": "Quint Code: Initialize FPF Project"
      },
      {
        "command": "quint-code.status",
        "title": "Quint Code: Show FPF Status"
      }
    ],
    "configuration": {
      "title": "Quint Code",
      "properties": {
        "quintCode.mcpServerPath": {
          "type": "string",
          "default": "",
          "description": "Path to quint-mcp binary (auto-detected if on PATH)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src/extension --ext ts",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
